{
    "name": "@nhankyjangchan/project-structure-generator",
    "version": "1.2.2",
    "private": false,
    "description": "Minimal and flexible CLI tool to scaffold a standardized Node.js/Bun backend folder structure with optional TypeScript, Prettier, and custom preset support",
    "keywords": [
        "scaffold",
        "project-generator",
        "project-template",
        "skeleton",
        "boilerplate",
        "backend-structure",
        "nodejs",
        "bun",
        "typescript",
        "prettier",
        "cli",
        "init",
        "generator",
        "structure",
        "setup"
    ],
    "homepage": "https://github.com/nhankyjangchan/project-structure-generator",
    "license": "MIT",
    "type": "module",
    "bin": {
        "psg": "./bin/index.js"
    },
    "exports": {
        ".": {
            "import": "./lib/index.js"
        },
        "./package.json": "./package.json"
    },
    "imports": {
        "#lib/*": "./lib/*"
    },
    "files": [
        "lib",
        "!lib/*.ts",
        "CHANGELOG.md",
        "LICENSE",
        "README.md",
        "package.json"
    ],
    "author": {
        "name": "Timur Schuchkin \"Nhankyjangchan\"",
        "email": "dev.schuchkin.timur@gmail.com",
        "url": "https://github.com/nhankyjangchan"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nhankyjangchan/project-structure-generator.git"
    },
    "bugs": {
        "url": "https://github.com/nhankyjangchan/project-structure-generator/issues",
        "email": "dev.schuchkin.timur@gmail.com"
    },
    "scripts": {
        "b:build": "bun build ./lib/index.ts --outfile ./bin/index.js --target node --format esm --minify",
        "p:write": "bunx prettier . --write"
    },
    "engines": {
        "node": ">=20.11.0",
        "npm": ">=8"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "prettier": "^3.8.3"
    }
}
